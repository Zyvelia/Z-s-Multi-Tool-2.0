── Your actual user data — NEVER commit this ────────────────────────────
# vault.json + master.key together = your real, decryptable passwords.
data/

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ── Vendored VLC runtime (optional, picked up by build.bat if present) ──
# Drop libvlc.dll/libvlccore.dll/plugins\ here yourself to build without
# needing VLC installed system-wide - but don't commit these, they're
# large binaries redistributed under VLC's own LGPL license, not our code.
/libvlc.dll
/libvlccore.dll
/plugins/

# ── PyInstaller build output (regenerated by build.bat) ─────────────────
build/
dist/
*.spec.bak

# ── Installer output (regenerated by installer build) ───────────────────
installer_output/

# ── Third-party binary, not our code — see Readme for how to get it ────
modules/folder_gen/assets/mGBA.exe

